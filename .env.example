# Firebase Configuration (Already configured)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=jalanea-works.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=jalanea-works
VITE_FIREBASE_STORAGE_BUCKET=jalanea-works.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Gemini AI Configuration (Already configured)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===== NEW: SerpApi & Google Maps Configuration =====
# These are SERVER-SIDE ONLY (no VITE_ prefix)
# Add these to Vercel Environment Variables

# SerpApi - For job scraping
# Get your key from: https://serpapi.com/dashboard
SERPAPI_KEY=your_serpapi_key_here

# Google Maps Distance Matrix API - For commute calculations
# Get your key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
