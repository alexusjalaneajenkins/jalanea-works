{
  "name": "apply-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "Human-in-the-loop mobile job application assistant",
  "scripts": {
    "build": "pnpm -C shared build && pnpm -C web build",
    "build:shared": "pnpm -C shared build",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern node_modules --ignore-pattern dist",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "typecheck": "pnpm -r typecheck",
    "clean": "rm -rf node_modules */node_modules */dist",
    "dev": "pnpm -C web dev",
    "start:web": "pnpm -C web start"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
