{
  "manifest_version": 3,
  "name": "Apply Co-Pilot Turbo",
  "version": "0.1.0",
  "description": "Human-in-the-loop job application assistant - Turbo Mode for Chrome",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.indeed.com/*",
    "https://indeed.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.indeed.com/*",
        "https://indeed.com/*"
      ],
      "js": ["src/content/indeed.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles/*", "assets/*"],
      "matches": ["https://www.indeed.com/*", "https://indeed.com/*"]
    }
  ]
}
