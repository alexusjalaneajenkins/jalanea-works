# ============================================
# VISION PROVIDER (choose one)
# ============================================
# Options: mock | gemini | claude
# - mock: FREE testing, no API calls (default)
# - gemini: Uses Gemini API (you already have this!)
# - claude: Uses Anthropic API
VISION_PROVIDER=mock

# ============================================
# API KEYS (only needed for non-mock modes)
# ============================================
# For VISION_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For VISION_PROVIDER=gemini (use your existing key from Jalanea Works!)
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# SERVER SETTINGS
# ============================================
# Server port (optional, default: 3001)
PORT=3001

# Run browser in headless mode (optional, default: true)
# Set to false to see the browser window during testing
HEADLESS=false

# Maximum actions per session (optional, default: 100)
MAX_ACTIONS=100
